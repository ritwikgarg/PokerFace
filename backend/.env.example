# ── Modal ──────────────────────────────────────────────────────
# Modal auth is handled via `modal token set` CLI — no env var needed.
# Secret name used in deployment: "agent-poker-keys"

# ── Supermemory ───────────────────────────────────────────────
SUPERMEMORY_API_URL=https://api.supermemory.ai
SUPERMEMORY_API_KEY=

# ── OpenAI (used by GPT-4o mini to summarize game history) ───
OPENAI_API_KEY=

# ── HuggingFace (needed for gated models like Llama) ─────────
HF_TOKEN=
